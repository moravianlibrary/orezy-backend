PWD_SECRET=GENERATED_SECRET  # Used to sign JWT tokens

POSTGRES_PASSWORD=PASSWORD  #  Secures backend DB for Hatchet
RABBITMQ_DEFAULT_PASS=PASSWORD  #  Secures queue management for Hatchet
MONGODB_PASS=PASSWORD  #  Secures database for tasks and results

MONGODB_URI="mongodb://autocrop-db-user:PASSWORD@mongo-db:27017/database_name?authSource=admin"
POSTGRES_URI="postgresql://hatchet:PASSWORD@postgres:5432/hatchet?sslmode=disable"
RABBITMQ_SERVER_URL=amqp://autocrop-rabbitmq-user:PASSWORD@rabbitmq:5672/
